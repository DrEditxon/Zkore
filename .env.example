# ── Football Data API ─────────────────────────────────────
# Get your free key at: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=

# ── Security Layer ──────────────────────────────────────────
# Enforce API Key authentication for programmatic access
ENFORCE_API_KEY=False
ZKORE_API_KEY=zkore-secret-dev-key

# ── Supabase (optional) ───────────────────────────────────
# Used for persisting predictions and history tracking.
# Get it at: https://supabase.com/
SUPABASE_URL=
SUPABASE_KEY=

# ── Cache (seconds) ───────────────────────────────────────
CACHE_DURATION=3600
CACHE_DURATION_HISTORICAL=86400

# ── Model ─────────────────────────────────────────────────
MIN_MATCHES_REQUIRED=30
