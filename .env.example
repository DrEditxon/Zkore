# ── Football Data API ─────────────────────────────────────
# Get your free key at: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=

# ── RapidAPI (optional) ───────────────────────────────────
# Used for detailed match stats in the prediction modal.
# Get it at: https://rapidapi.com/api-sports/api/api-football
RAPIDAPI_KEY=
RAPIDAPI_HOST=api-football-v1.p.rapidapi.com

# ── Supabase (optional) ───────────────────────────────────
# Used for persisting predictions and history tracking.
# Get it at: https://supabase.com/
SUPABASE_URL=
SUPABASE_KEY=

# ── Cache (seconds) ───────────────────────────────────────
CACHE_DURATION=3600
CACHE_DURATION_HISTORICAL=86400

# ── Model ─────────────────────────────────────────────────
MIN_MATCHES_REQUIRED=30
